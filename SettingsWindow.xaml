<Window x:Class="FluentClip.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="设置"
        Height="540" Width="370"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Border Background="#F5F5F7" CornerRadius="14" BorderBrush="#E8E8E8" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Ellipse Width="12" Height="12" Fill="#FF5F57" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="CloseButton_Click"/>
                            <Ellipse Width="12" Height="12" Fill="#FFBD2E" Margin="0,0,8,0" Visibility="Collapsed"/>
                            <Ellipse Width="12" Height="12" Fill="#28C840" Visibility="Collapsed"/>
                        </StackPanel>
                        <TextBlock Text="设置" FontSize="12" FontWeight="500" Foreground="#6E6E73" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    <TextBlock Text="通用" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,20">
                        <CheckBox x:Name="AutoStartCheckBox" Content="开机自启动" FontSize="13" 
                                  Foreground="#3D3D3D" Margin="0,0,0,10" Cursor="Hand"/>
                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="最小化到系统托盘" FontSize="13" 
                                  Foreground="#3D3D3D" Margin="0,0,0,10" Cursor="Hand"/>
                        <CheckBox x:Name="RunInBackgroundCheckBox" Content="关闭时保持后台运行" FontSize="13" 
                                  Foreground="#3D3D3D" Cursor="Hand"/>
                    </StackPanel>

                    <TextBlock Text="剪贴板" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,20">
                        <CheckBox x:Name="MonitorClipboardCheckBox" Content="监控系统剪贴板" FontSize="13" 
                                  Foreground="#3D3D3D" Margin="0,0,0,10" Cursor="Hand"/>
                        
                        <TextBlock Text="拖入文件行为:" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <RadioButton x:Name="DragCopyRadio" Content="仅保存副本（复制）" FontSize="12" 
                                         Foreground="#3D3D3D" Margin="0,0,16,0" Cursor="Hand" GroupName="DragAction"/>
                            <RadioButton x:Name="DragCutRadio" Content="剪切原文件" FontSize="12" 
                                         Foreground="#3D3D3D" Cursor="Hand" GroupName="DragAction"/>
                        </StackPanel>
                    </StackPanel>

                    <TextBlock Text="快捷键设置" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,8"/>
                    <TextBlock Text="点击输入框并按下快捷键" FontSize="11" Foreground="#8E8E93" Margin="0,0,0,12"/>

                    <StackPanel Margin="0,0,0,20">
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="显示主窗口" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,5">
                                <TextBox x:Name="ShowHotkeyTextBox" FontSize="12" BorderThickness="0" Background="Transparent" 
                                         Width="100" Foreground="#3D3D3D" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" PreviewGotKeyboardFocus="HotkeyTextBox_PreviewGotKeyboardFocus"/>
                            </Border>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <TextBlock Text="打开设置" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,5">
                                <TextBox x:Name="SettingsHotkeyTextBox" FontSize="12" BorderThickness="0" Background="Transparent" 
                                         Width="100" Foreground="#3D3D3D" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" PreviewGotKeyboardFocus="HotkeyTextBox_PreviewGotKeyboardFocus"/>
                            </Border>
                        </Grid>
                        <Grid>
                            <TextBlock Text="置顶切换" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                            <Border HorizontalAlignment="Right" Background="White" CornerRadius="6" BorderBrush="#E8E8E8" BorderThickness="1" Padding="10,5">
                                <TextBox x:Name="PinHotkeyTextBox" FontSize="12" BorderThickness="0" Background="Transparent" 
                                         Width="100" Foreground="#3D3D3D" PreviewKeyDown="HotkeyTextBox_PreviewKeyDown" PreviewGotKeyboardFocus="HotkeyTextBox_PreviewGotKeyboardFocus"/>
                            </Border>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
