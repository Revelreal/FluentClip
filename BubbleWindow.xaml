<Window x:Class="FluentClip.BubbleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bubble"
        Width="280" Height="80"
        MinHeight="60" MaxHeight="400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    
    <Border Background="#E8F4FC"
            CornerRadius="18"
            Padding="16,12"
            BorderBrush="#A8D8EA"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#A8D8EA" BlurRadius="12" ShadowDepth="4" Opacity="0.6"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="🐱" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock x:Name="MessageText"
                       Text="检测到新文件喵~"
                       FontSize="14"
                       Foreground="#5B7C99"
                       TextWrapping="Wrap"
                       TextAlignment="Center"
                       MaxWidth="250"
                       FontFamily="Microsoft YaHei UI, Segoe UI Emoji"/>
        </StackPanel>
    </Border>
</Window>
