<Window x:Class="FluentClip.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FluentClip"
        xmlns:vm="clr-namespace:FluentClip.ViewModels"
        mc:Ignorable="d"
        Title="FluentClip"
        Height="560" Width="450"
        MinHeight="560" MinWidth="425"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <!-- Softer, more subtle shadow for macOS style -->
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Opacity="0.08" Color="#000000"/>

        <!-- macOS Style Colors - More subtle palette -->
        <SolidColorBrush x:Key="MacBackground" Color="#F9F9F9"/>
        <SolidColorBrush x:Key="MacCardBg" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="MacPrimary" Color="#007AFF"/>
        <SolidColorBrush x:Key="MacPrimaryHover" Color="#0066DD"/>
        <SolidColorBrush x:Key="MacTextPrimary" Color="#1D1D1F"/>
        <SolidColorBrush x:Key="MacTextSecondary" Color="#86868B"/>
        <SolidColorBrush x:Key="MacBorder" Color="#E5E5E5"/>
        <SolidColorBrush x:Key="MacUserBubble" Color="#007AFF"/>
        <SolidColorBrush x:Key="MacAiBubble" Color="#FFFFFF"/>

        <!-- Typography -->
        <Style x:Key="MacTitle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Segoe UI, -apple-system, BlinkMacSystemFont, sans-serif"/>
            <Setter Property="FontWeight" Value="600"/>
        </Style>

        <Style x:Key="EmojiText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI Emoji, Apple Color Emoji, Noto Color Emoji, sans-serif"/>
        </Style>
    </Window.Resources>

    <Border x:Name="MainBorder" Background="#F9F9F9" CornerRadius="16" BorderBrush="#E5E5E5" BorderThickness="1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="225"/>
                <ColumnDefinition x:Name="AgentColumn" Width="0" MinWidth="0"/>
            </Grid.ColumnDefinitions>
            
            <Grid x:Name="ToastContainer" Panel.ZIndex="1000" Grid.ColumnSpan="2">
                <Border x:Name="ToastPopup" Background="#323232" CornerRadius="24" Padding="16,10" 
                        HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,20"
                        Opacity="0">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3" Color="#000000"/>
                    </Border.Effect>
                    <TextBlock x:Name="ToastText" Foreground="White" FontSize="13" FontWeight="500">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontFamily" Value="Segoe UI Emoji, Apple Color Emoji, Noto Color Emoji, sans-serif"/>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
            
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="16,16,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                            <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                                <Ellipse Width="12" Height="12" Fill="#FF5F57" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="CloseButton_Click"/>
                                <Ellipse Width="12" Height="12" Fill="#FFBD2E" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="MinimizeButton_Click"/>
                                <Ellipse Width="12" Height="12" Fill="#28C840" Cursor="Hand" MouseLeftButtonDown="MaximizeButton_Click"/>
                            </StackPanel>
                            <TextBlock Text="FluentClip" FontSize="12" FontWeight="500" Foreground="#6E6E73" VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button x:Name="SettingsButton" Click="SettingsButton_Click" ToolTip="设置" Cursor="Hand" 
                                Width="28" Height="22" Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Right" Margin="0,0,40,0">
                            <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                  Fill="#6E6E73" Width="12" Height="12" Stretch="Uniform"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E8E8ED"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="PinButton" Click="PinButton_Click" ToolTip="置顶" Cursor="Hand" 
                                Width="28" Height="22" Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Right" Margin="0,0,70,0">
                            <TextBlock Text="📌" FontSize="10" Style="{StaticResource EmojiText}"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E8E8ED"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <Button x:Name="AgentButton" Click="AgentButton_Click" ToolTip="AI Agent" Cursor="Hand" 
                                Width="28" Height="22" Background="Transparent" BorderThickness="0"
                                HorizontalAlignment="Right" Margin="0,0,8,0">
                            <Path Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,17V16H9V14H13V13H10A1,1 0 0,1 9,12V9A1,1 0 0,1 10,8H11V7H13V8H15V10H11V11H14A1,1 0 0,1 15,12V15A1,1 0 0,1 14,16H13V17H11Z" 
                                  Fill="#6E6E73" Width="14" Height="14" Stretch="Uniform"/>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#E8E8ED"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" x:Name="DropZone" Margin="16,16,16,0" CornerRadius="14" 
                            AllowDrop="True" Cursor="Hand"
                            MouseLeftButtonDown="DropZone_Click"
                            DragEnter="DropZone_DragEnter" DragLeave="DropZone_DragLeave" Drop="DropZone_Drop">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="BorderBrush" Value="#E5E5E5"/>
                                <Setter Property="Background" Value="#FFFFFF"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F5F5F7"/>
                                        <Setter Property="BorderBrush" Value="#007AFF"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="30">
                            <TextBlock Text="+" FontSize="32" HorizontalAlignment="Center" Foreground="#AEAEB2" FontWeight="Light"/>
                            <TextBlock Text="拖放或点击上传" FontSize="13" Foreground="#AEAEB2" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="1" Margin="0,16,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="20,0">
                            <TextBlock Text="剪贴板" FontSize="13" FontWeight="500" Foreground="#1C1C1E" VerticalAlignment="Center"/>
                            <Button Content="清空" HorizontalAlignment="Right" Command="{Binding ClearAllCommand}"
                                    Background="Transparent" BorderThickness="0" Foreground="#8E8E93" FontSize="12" Cursor="Hand"/>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="8,8,8,12">
                            <ItemsControl ItemsSource="{Binding ClipboardItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border x:Name="ItemCard" Background="#FFFFFF" CornerRadius="12"
                                                Margin="6,4" Padding="12" Cursor="Hand"
                                                MouseMove="ItemCard_MouseMove" MouseLeftButtonDown="ItemCard_MouseLeftButtonDown" MouseLeftButtonUp="ItemCard_MouseLeftButtonUp"
                                                Tag="{Binding}" Effect="{StaticResource CardShadow}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="#F0F0F0"/>
                                                    <Setter Property="BorderThickness" Value="1"/>
                                                    <Style.Triggers>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FAFAFA"/>
                                                            <Setter Property="BorderBrush" Value="#E0E0E0"/>
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Grid Grid.Column="0" Width="40" Height="40" Margin="0,0,12,0">
                                                    <Image Source="{Binding Thumbnail}" Stretch="UniformToFill">
                                                        <Image.Clip>
                                                            <EllipseGeometry Center="20,20" RadiusX="20" RadiusY="20"/>
                                                        </Image.Clip>
                                                    </Image>
                                                </Grid>
                                                
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding DisplayText}" FontSize="13" Foreground="#3D3D3D"
                                                              TextTrimming="CharacterEllipsis" MaxHeight="20">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="ToolTip" Value="{Binding DisplayText}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ItemType}" Value="File">
                                                                        <Setter Property="ToolTip" Value="{Binding FullPath}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock FontSize="10" Foreground="#AEAEB2" Margin="0,4,0,0">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Text" Value="{Binding Timestamp, StringFormat='{}{0:HH:mm}'}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding ItemType}" Value="File">
                                                                        <Setter Property="Text" Value="{Binding FileTypeFormat}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ItemType}" Value="Image">
                                                                        <Setter Property="Text" Value="{Binding FileTypeFormat}"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding ItemType}" Value="Text">
                                                                        <Setter Property="Text" Value="{Binding TextTypeFormat}"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <Button Grid.Column="2" Content="✕" FontSize="9"
                                                        VerticalAlignment="Top" HorizontalAlignment="Right"
                                                        Cursor="Hand" Padding="6"
                                                        Foreground="#C7C7CC"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="Button">
                                                                        <Border x:Name="border" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="border" Property="Background" Value="#FFE5E5"/>
                                                                                <Setter Property="Foreground" Value="#FF3B30"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </Button.Style>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Grid>
            </Grid>

            <Border Grid.Column="1" x:Name="AgentSidebar" Background="#F9F9F9" CornerRadius="0,16,16,0" BorderBrush="#E5E5E5" BorderThickness="1,0,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="0,16,0,0" MouseLeftButtonDown="AgentTitleBar_MouseLeftButtonDown">
                        <Grid>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                                <TextBlock Text="AI Agent" FontSize="12" FontWeight="500" Foreground="#6E6E73" VerticalAlignment="Center"/>
                            </StackPanel>

                            <Button x:Name="AgentSettingsBtn" Click="AgentSettingsButton_Click" ToolTip="设置" Cursor="Hand" 
                                    Width="28" Height="22" Background="Transparent" BorderThickness="0"
                                    HorizontalAlignment="Right" Margin="0,0,8,0">
                                <Path Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.21,8.95 2.27,9.22 2.46,9.37L4.57,11C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.21,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.03 4.95,18.95L7.44,17.94C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.67 16.04,18.34 16.56,17.94L19.05,18.95C19.27,19.03 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z" 
                                  Fill="#6E6E73" Width="12" Height="12" Stretch="Uniform"/>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#E8E8ED"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <ScrollViewer x:Name="AgentChatScrollViewer" Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12">
                        <StackPanel x:Name="AgentChatPanel">
                            <Border CornerRadius="16" Padding="14" Margin="0,8" Effect="{StaticResource CardShadow}">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#FFF8F0" Offset="0"/>
                                        <GradientStop Color="#F0F8FF" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="18" Margin="0,0,12,0" ClipToBounds="True">
                                        <Image x:Name="AgentAvatarImage" Stretch="UniformToFill"/>
                                    </Border>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🐱 猫羽雫" FontWeight="600" FontSize="13" Foreground="#6B4C9A"/>
                                            <Border Background="#FFF0F5" CornerRadius="8" Padding="6,2" Margin="8,0,0,0">
                                                <TextBlock Text="AI助手" FontSize="9" Foreground="#DB7093"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="你好呀~我是雫，一只可爱的小猫咪🐾 可以帮你分析剪贴板、聊天、搜索信息哦~有什么想问的尽管告诉我吧！" 
                                                  FontSize="11" Foreground="#666666" TextWrapping="Wrap" MaxWidth="175" Margin="0,4,0,0" LineHeight="16"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border x:Name="TokenUsageBorder" Grid.Row="2" Background="#F5F5F7" Padding="10,6" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Visibility="Visible">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="TokenUsageText" Text="上下文: 0 / 100000" FontSize="10" Foreground="#8E8E93" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TokenPercentageText" Text=" (0%)" FontSize="10" Foreground="#8E8E93" VerticalAlignment="Center" Margin="2,0,0,0"/>
                            </StackPanel>
                            <Button x:Name="SummarizeButton" Grid.Column="1" Content="总结" FontSize="10" 
                                    Padding="8,2" Background="#E8E8E8" BorderThickness="0" Cursor="Hand" 
                                    Click="SummarizeButton_Click" ToolTip="手动触发上下文总结">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="4">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#D0D0D0"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3" Background="#FFFFFF" CornerRadius="0,0,16,0" Padding="10" BorderBrush="#E5E5E5" BorderThickness="0,1,0,0" Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBox x:Name="AgentInputTextBox" Grid.Column="0"
                                     FontSize="13" Foreground="#1D1D1F"
                                     Background="#F5F5F7" BorderThickness="0"
                                     Padding="12,8" VerticalContentAlignment="Center"
                                     KeyDown="AgentInputTextBox_KeyDown">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="TextBox">
                                                    <Border Background="#F5F5F7" CornerRadius="10">
                                                        <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                                                    </Border>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>

                            <Button x:Name="AgentCancelButton" Click="AgentCancelButton_Click" Cursor="Hand" 
                                    Grid.Column="1"
                                    Width="28" Height="28" Background="#FF3B30" BorderThickness="0"
                                    Margin="6,0,0,0" Visibility="Collapsed">
                                <Path Data="M6,6L18,18M18,6L6,18" 
                                      Fill="White" Width="10" Height="10" Stretch="Uniform" Stroke="White" StrokeThickness="2"/>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#D32F2F"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                            <Button x:Name="AgentSendButton" Click="AgentSendButton_Click" Cursor="Hand" 
                                    Grid.Column="1"
                                    Width="28" Height="28" Background="#007AFF" BorderThickness="0"
                                    Margin="6,0,0,0">
                                <Path Data="M2,21L23,12L2,3V10L17,12L2,14V21Z" 
                                      Fill="White" Width="12" Height="12" Stretch="Uniform"/>
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="border" Property="Background" Value="#0056B3"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
