<Window x:Class="FluentClip.AgentSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI Agent 设置"
        Height="520" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None">

    <Window.Resources>
        <Style x:Key="ToggleSwitch" TargetType="CheckBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Width="32" Height="18">
                            <Border x:Name="Background" CornerRadius="9" Background="#E8E8E8" Cursor="Hand"/>
                            <Border x:Name="Thumb" Width="14" Height="14" CornerRadius="7" Background="White" 
                                    HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Border.RenderTransform>
                                    <TranslateTransform x:Name="ThumbTransform" X="0"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="2" ShadowDepth="0.5" Opacity="0.15" Color="Black"/>
                                </Border.Effect>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#34C759"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" 
                                                           Storyboard.TargetProperty="X"
                                                           To="16" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="ThumbTransform" 
                                                           Storyboard.TargetProperty="X"
                                                           To="0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#F5F5F7" CornerRadius="14" BorderBrush="#E8E8E8" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="#FFFFFF" CornerRadius="14,14,0,0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                            <Ellipse Width="12" Height="12" Fill="#FF5F57" Margin="0,0,8,0" Cursor="Hand" MouseLeftButtonDown="CloseButton_Click"/>
                            <Ellipse Width="12" Height="12" Fill="#FFBD2E" Visibility="Hidden"/>
                            <Ellipse Width="12" Height="12" Fill="#28C840" Visibility="Hidden"/>
                        </StackPanel>
                        <TextBlock Text="AI Agent 设置" FontSize="12" FontWeight="500" Foreground="#6E6E73" VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="20">
                <StackPanel>
                    <TextBlock Text="API 配置" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,12"/>

                    <TextBlock Text="Base URL" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <TextBox x:Name="BaseUrlTextBox" FontSize="12" Padding="10,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,12"/>

                    <TextBlock Text="API Key" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <PasswordBox Grid.Column="0" x:Name="ApiKeyBox" FontSize="12" Padding="10,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,8,12"/>
                        <Button Grid.Column="1" x:Name="SubscribeButton" Content="订阅 Coding Plan" Click="SubscribeButton_Click"
                                FontSize="11" Padding="10,8" Background="#E8E8E8" Foreground="#3D3D3D" BorderThickness="0" 
                                Cursor="Hand" Margin="0,0,0,12"/>
                    </Grid>

                    <TextBlock Text="模型名称" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <TextBox x:Name="ModelTextBox" FontSize="12" Padding="10,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,0,12"/>

                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="使用流式回复" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                        <CheckBox x:Name="StreamingCheckBox" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Cursor="Hand"/>
                    </Grid>
                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="开启工具调用能力（实验性）" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                        <CheckBox x:Name="EnableToolCallsCheckBox" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Cursor="Hand"/>
                    </Grid>

                    <TextBlock Text="人格设定" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,20,0,12"/>

                    <TextBlock Text="人格提示词 (可编辑)" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <TextBox x:Name="PersonaPromptTextBox" FontSize="12" Padding="10,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="80" Margin="0,0,0,20"/>

                    <TextBlock Text="系统提示词 (固定，不可修改)" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <TextBox x:Name="SystemPromptTextBox" FontSize="12" Padding="10,8" Background="#F5F5F5" BorderBrush="#E8E8E8" BorderThickness="1"
                             TextWrapping="Wrap" AcceptsReturn="True" Height="100" IsReadOnly="True" Foreground="#666666" Margin="0,0,0,20"/>

                    <TextBlock Text="头像设置" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,12"/>

                    <Button x:Name="AvatarButton" Click="AvatarButton_Click" Content="选择头像图片" 
                            FontSize="12" Padding="12,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1" 
                            Cursor="Hand" HorizontalAlignment="Left" Margin="0,0,0,8"/>

                    <TextBlock x:Name="AvatarPathText" FontSize="11" Foreground="#8E8E93" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="高级功能" FontSize="13" FontWeight="600" Foreground="#1C1C1E" Margin="0,0,0,12"/>
                    
                    <TextBlock Text="AI工作文件夹" FontSize="12" Foreground="#6E6E73" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="AiWorkFolderTextBox" Grid.Column="0" FontSize="12" Padding="10,8" Background="White" BorderBrush="#E8E8E8" BorderThickness="1" Margin="0,0,8,0"/>
                        <Button Grid.Column="1" x:Name="BrowseAiWorkFolderButton" Content="浏览" Click="BrowseAiWorkFolderButton_Click"
                                FontSize="11" Padding="10,8" Background="#E8E8E8" Foreground="#3D3D3D" BorderThickness="0" Cursor="Hand"/>
                    </Grid>
                    <TextBlock Text="设置后，该文件夹中的文件会自动添加到剪贴板暂存区" FontSize="10" Foreground="#8E8E93" TextWrapping="Wrap" Margin="0,0,0,12"/>
                    
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="启用Shell命令执行" FontSize="12" Foreground="#3D3D3D" VerticalAlignment="Center"/>
                            <TextBlock Text="允许AI执行CMD/PowerShell命令（高风险命令需要确认）" FontSize="10" Foreground="#8E8E93" TextWrapping="Wrap" Margin="0,2,0,0"/>
                        </StackPanel>
                        <CheckBox x:Name="EnableShellExecutionCheckBox" Style="{StaticResource ToggleSwitch}" Grid.Column="1" Cursor="Hand" VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
